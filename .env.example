DATABASE_URL="postgresql://postgres:postgres@db:5432/sill"
MASTODON_REDIRECT_URI="http://127.0.0.1:3000/mastodon/auth/callback/"
ENVIRONMENT=local
NODE_ENV=development
USE_SSL=false
TRAEFIK_DASHBOARD_AUTH=admin:user:password
WEB_DOMAIN=localhost
DOZZLE_DOMAIN=dozzle.localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sill
UPDATE_BATCH_SIZE=50
VITE_PUBLIC_DOMAIN=http://127.0.0.1:3000

# Fill these out
MAILGUN_API_KEY=
VITE_ADMIN_EMAIL=
EMAIL_DOMAIN=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SCRAPE_SHARE_THRESHOLD=5

# Sill AppView API (Bluesky timeline source). When both are set, the default
# /links timeline pulls Bluesky shares from the AppView instead of the DB.
# Leave empty to fall back to the DB aggregation everywhere.
# APPVIEW_API_URL=http://10.0.0.5:3000
# APPVIEW_API_KEY=

# APNs (push notifications)
# APNS_KEY_FILE=/path/to/apns-key.p8
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=

# Optional
# POLAR_WEBHOOK_SECRET=
# POLAR_ACCESS_TOKEN=
# SUCCESS_URL=
